<Window x:Class="AbyssOverlay.HelpOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abyss Help"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResize">
    <Window.Resources>
        <LinearGradientBrush x:Key="HelpHeaderBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1E2A33" Offset="0"/>
            <GradientStop Color="#121A22" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HelpBodyBg" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#141C24" Offset="0"/>
            <GradientStop Color="#0F1419" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="HelpCardBg" Color="#11161C"/>
        <SolidColorBrush x:Key="HelpCardBorder" Color="#2A3A44"/>
    </Window.Resources>

    <Grid Margin="10">
        <Border x:Name="RootBorder"
                Background="{StaticResource OverlayBg}"
                BorderBrush="{StaticResource OverlayBorder}"
                BorderThickness="1.2"
                CornerRadius="16"
                Effect="{StaticResource OverlayShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource HelpHeaderBg}"
                        CornerRadius="16,16,0,0"
                        BorderBrush="{StaticResource OverlayBorder}"
                        BorderThickness="0,0,0,1"
                        Padding="12,10">
                    <DockPanel LastChildFill="True">
                        <Border Width="10" Height="10"
                                Background="{StaticResource OverlayAccent}"
                                CornerRadius="5"
                                Margin="0,2,10,0"/>
                        <StackPanel>
                            <TextBlock x:Name="RoomTitle"
                                       Text="Abyss Help"
                                       Foreground="{StaticResource OverlayText}"
                                       FontWeight="SemiBold"
                                       FontSize="16"/>
                            <TextBlock x:Name="RoomSubtitle"
                                       Text="Заметка"
                                       Foreground="{StaticResource OverlayMuted}"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Background="#252F38"
                                BorderBrush="{StaticResource OverlayBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,2"
                                Margin="8,0,0,0">
                            <TextBlock Text="ABYSS"
                                       Foreground="{StaticResource OverlayAccent}"
                                       FontWeight="SemiBold"
                                       FontSize="11"/>
                        </Border>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource HelpBodyBg}"
                        CornerRadius="0,0,16,16"
                        Padding="12">
                    <Grid>
                        <Border x:Name="MessagePanel"
                                Background="{StaticResource HelpCardBg}"
                                BorderBrush="{StaticResource HelpCardBorder}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Visibility="Collapsed">
                            <TextBlock x:Name="MessageText"
                                       Foreground="{StaticResource OverlayText}"
                                       TextWrapping="Wrap"
                                       FontSize="13"/>
                        </Border>

                        <Border x:Name="DataPanel"
                                Background="{StaticResource HelpCardBg}"
                                BorderBrush="{StaticResource HelpCardBorder}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="Приоритет"
                                                   Foreground="{StaticResource OverlayText}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"/>
                                        <Rectangle DockPanel.Dock="Right"
                                                   Width="120"
                                                   Height="2"
                                                   Fill="{StaticResource OverlayAccent}"
                                                   Opacity="0.35"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="#" Foreground="{StaticResource OverlayMuted}" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="Цель" Foreground="{StaticResource OverlayMuted}" FontSize="11"/>
                                        <TextBlock Grid.Column="2" Text="Роль" Foreground="{StaticResource OverlayMuted}" FontSize="11"/>
                                        <TextBlock Grid.Column="3" Text="Комментарий" Foreground="{StaticResource OverlayMuted}" FontSize="11"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding PriorityRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource HelpCardBorder}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="34"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="110"/>
                                                            <ColumnDefinition Width="2*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Num}"
                                                                   Foreground="{StaticResource OverlayAccent}"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Target}"
                                                                   Foreground="{StaticResource OverlayText}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Role}"
                                                                   Foreground="{StaticResource OverlayMuted}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding Details}"
                                                                   Foreground="{StaticResource OverlayText}"
                                                                   TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <DockPanel Margin="0,10,0,6">
                                        <TextBlock Text="Заметки"
                                                   Foreground="{StaticResource OverlayText}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"/>
                                        <Rectangle DockPanel.Dock="Right"
                                                   Width="120"
                                                   Height="2"
                                                   Fill="{StaticResource OverlayAccent}"
                                                   Opacity="0.35"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <ItemsControl ItemsSource="{Binding Notes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Fill="{StaticResource OverlayAccent}"
                                                             Width="4"
                                                             Height="4"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding}"
                                                               Foreground="{StaticResource OverlayText}"
                                                               TextWrapping="Wrap"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <ResizeGrip x:Name="HelpResizeGrip"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="10"
                            Foreground="{StaticResource OverlayAccent}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
