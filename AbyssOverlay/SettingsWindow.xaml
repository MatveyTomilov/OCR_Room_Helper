<Window x:Class="AbyssOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abyss Overlay Settings"
        Height="480" Width="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Foreground="{StaticResource OverlayText}">
    <Grid Margin="8">
        <Border Background="{StaticResource OverlayBgStrong}"
                BorderBrush="{StaticResource OverlayBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Effect="{StaticResource OverlayShadow}">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel x:Name="TitleBar" Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
                    <TextBlock Text="Abyss Overlay" Foreground="{StaticResource OverlayText}" FontWeight="SemiBold" FontSize="14"/>
                    <Button Content="✕" Width="26" Height="26" HorizontalAlignment="Right" Margin="8,0,0,0"
                            Foreground="{StaticResource OverlayText}" Background="Transparent" BorderBrush="{StaticResource OverlayBorder}"
                            BorderThickness="1" Click="CloseButton_Click"/>
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Content="Select region" Click="SelectRegion_Click"/>
                    <Button Content="Analyze (OCR)" Click="Analyze_Click"/>
                    <Button Content="Reload Excel" Click="Reload_Click"/>
                    <Button Content="Quit" Click="Quit_Click"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" Grid.Row="2" Margin="0,10,0,10" TextWrapping="Wrap" Foreground="{StaticResource OverlayMuted}"/>

                <GroupBox Header="Help Overlay" Grid.Row="3" Margin="0,0,0,10" BorderBrush="{StaticResource OverlayBorder}">
                    <StackPanel Margin="8">
                        <CheckBox x:Name="ShowOverlayCheck" Content="Show help overlay" Checked="OverlayChanged" Unchecked="OverlayChanged"/>
                        <CheckBox x:Name="LockOverlayCheck" Content="Lock overlay (click-through)" Checked="OverlayChanged" Unchecked="OverlayChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Opacity" VerticalAlignment="Center" Width="70"/>
                            <Slider x:Name="OpacitySlider" Minimum="0.2" Maximum="1.0" ValueChanged="OpacitySlider_ValueChanged" Width="300"/>
                            <TextBlock x:Name="OpacityValue" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="Save overlay position" HorizontalAlignment="Left" Click="SaveOverlay_Click"/>
                        <TextBlock Text="Tip: Unlock overlay to move/resize. Then lock for click-through." Margin="0,6,0,0" Foreground="{StaticResource OverlayMuted}"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock Grid.Row="4" TextWrapping="Wrap" Foreground="{StaticResource OverlayMuted}">
                    Hotkeys:\n  Ctrl+Alt+R - select region\n  Ctrl+Alt+S - analyze\n  Ctrl+Alt+Q - quit
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
