<Window x:Class="AbyssOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abyss"
        Width="140" Height="44"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Topmost="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Grid>
        <Border Background="{StaticResource OverlayBgStrong}"
                BorderBrush="{StaticResource OverlayBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Effect="{StaticResource OverlayShadow}">
            <Button x:Name="OverlayButton"
                    Content="ABYSS"
                    Style="{StaticResource OverlayButtonStyle}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="8,4" />
        </Border>
    </Grid>
</Window>
